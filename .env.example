# ===========================================
# FinBrain 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ===========================================

# ===========================================
# 数据库配置
# ===========================================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=financial_report
MYSQL_USER=fin_user
MYSQL_PASSWORD=fin_pass123
MYSQL_PORT=3306

# ===========================================
# 应用配置
# ===========================================
APP_PORT=8501

# ===========================================
# LLM API 配置
# 说明：也可以在页面侧边栏直接配置
# ===========================================

# DeepSeek（推荐用于财报分析）
# 获取 API Key: https://platform.deepseek.com/api_keys
LLM_API_KEY=sk-76f4b259f25147879777441ce24a0644
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 阿里云百炼/通义千问
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# 百度 - 文心一言
# 获取 API Key: https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
# LLM_API_KEY=xxx
# LLM_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1
# LLM_MODEL=ernie-4.0

# 智谱 AI - GLM
# 获取 API Key: https://open.bigmodel.cn/usercenter/apikeys
# LLM_API_KEY=xxx
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4

# 月之暗面 - Kimi
# 获取 API Key: https://platform.moonshot.cn/console/apikeys
# LLM_API_KEY=xxx
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# 零一万物 - Yi
# 获取 API Key: https://platform.lingyiwanwu.com/apikeys
# LLM_API_KEY=xxx
# LLM_BASE_URL=https://api.lingyiwanwu.com/v1
# LLM_MODEL=yi-large

# ===========================================
# 可选配置
# ===========================================
DEBUG=true
TZ=Asia/Shanghai
