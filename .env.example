# ===========================================
# 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ===========================================

# ===========================================
# 数据库配置
# ===========================================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=financial_report
MYSQL_USER=fin_user
MYSQL_PASSWORD=fin_pass123
MYSQL_PORT=3306

# ===========================================
# 应用配置
# ===========================================
APP_PORT=8501
STREAMLIT_PORT=8502

# ===========================================
# LLM API 配置
# 说明：可以在页面侧边栏直接配置，无需修改此文件
# ===========================================

# 阿里云百炼/通义千问
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
# ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ANTHROPIC_AUTH_TOKEN=sk-xxx
# ANTHROPIC_MODEL=qwen-plus

# 百度 - 文心一言
# 获取 API Key: https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
# ANTHROPIC_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1
# ANTHROPIC_AUTH_TOKEN=xxx
# ANTHROPIC_MODEL=ernie-4.0

# 智谱 AI - GLM
# 获取 API Key: https://open.bigmodel.cn/usercenter/apikeys
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ANTHROPIC_AUTH_TOKEN=xxx
# ANTHROPIC_MODEL=glm-4

# 月之暗面 - Kimi
# 获取 API Key: https://platform.moonshot.cn/console/apikeys
# ANTHROPIC_BASE_URL=https://api.moonshot.cn/v1
# ANTHROPIC_AUTH_TOKEN=xxx
# ANTHROPIC_MODEL=moonshot-v1-8k

# 深度求索 - DeepSeek
# 获取 API Key: https://platform.deepseek.com/api_keys
# ANTHROPIC_BASE_URL=https://api.deepseek.com/v1
# ANTHROPIC_AUTH_TOKEN=xxx
# ANTHROPIC_MODEL=deepseek-chat

# 零一万物 - Yi
# 获取 API Key: https://platform.lingyiwanwu.com/apikeys
# ANTHROPIC_BASE_URL=https://api.lingyiwanwu.com/v1
# ANTHROPIC_AUTH_TOKEN=xxx
# ANTHROPIC_MODEL=yi-large

# ===========================================
# 可选配置
# ===========================================
DEBUG=true
TZ=Asia/Shanghai
